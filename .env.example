# Supabase（登录、云端项目、异步 LLM 报告）
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# 以下密钥仅在 Netlify / Supabase Edge Functions 中配置，不要暴露到前端
SILICONFLOW_API_KEY=your-siliconflow-api-key
PADDLEOCR_TOKEN=your-paddleocr-token

# Supabase Edge Function 部署时在 Dashboard → Edge Functions → Secrets 中设置：
# SILICONFLOW_API_KEY=...
# SUPABASE_SERVICE_ROLE_KEY=...（Supabase 自动注入 SUPABASE_URL / SUPABASE_ANON_KEY）
