# Supabase（登录、云端项目、Supabase Edge Function 长任务）
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# 以下密钥仅在 Netlify / Supabase Edge Functions 中配置，不要暴露到前端
SILICONFLOW_API_KEY=your-siliconflow-api-key
PADDLEOCR_TOKEN=your-paddleocr-token

# Supabase Edge Function 部署时在 Dashboard → Edge Functions → Secrets 中设置：
# SILICONFLOW_API_KEY=...        （start-report-job 用）
# PADDLEOCR_TOKEN=...            （start-ocr-job 用）
